{
  "name": "buff-eat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BUFF EAT — умный помощник закупки продуктов для фитнес-тренеров и их клиентов",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@preact/signals": "^1.2.3",
    "preact": "^10.19.3",
    "wouter-preact": "^3.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.1",
    "@testing-library/preact": "^3.2.3",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.1"
  }
}
